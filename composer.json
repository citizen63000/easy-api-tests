{
    "name": "citizen63000/easy-api-tests",
    "description": "",
    "keywords": ["api", "rest", "tests"],
    "license": "MIT",
    "type": "symfony-bundle",
    "authors": [
        {"name": "citizen63000"},
        {"name": "DarwinOnLine"}
    ],
    "require": {
        "php": "^8.3",
        "citizen63000/easy-api-core": "dev-main|^2.0",
        "namshi/jose": "^7.2|^8.0",
        "phpunit/php-code-coverage": "^9.2",
        "phpunit/phpunit": "^9.6",
        "psr/http-message": "^2.0",
        "symfony/browser-kit": "^6.4",
        "symfony/error-handler": "^6.4",
        "symfony/mime": "^6.4",
        "symfony/phpunit-bridge": "^6.4",
        "symfony/stopwatch": "^6.4",
        "symfony/web-profiler-bundle": "^6.4"
    },
    "require-dev": {
        "composer/xdebug-handler": "^3.0",
        "friendsofphp/php-cs-fixer": "*"
    },
    "config": {
        "discard-changes": true,
        "platform": {
            "php": "8.3"
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "EasyApiTests\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EasyApiTests\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": [
            "Composer\\Config::disableProcessTimeout",
            "php vendor/bin/phpunit"
        ],
        "clean-code": "PHP_CS_FIXER_IGNORE_ENV=1 php vendor/friendsofphp/php-cs-fixer/php-cs-fixer fix . --config=.php-cs --path-mode=intersection --verbose"
    }
}
